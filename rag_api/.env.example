# Core
RAG_INDEX_PATH=../assets/local_pdf_rag_index.json
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
QUERY_PREFIX=为这个句子生成表示以用于检索相关文章：
TOP_K=8
CANDIDATE_K=60
HYBRID_ALPHA=0.68

# Optional reranker. Stronger but slower and heavier.
ENABLE_RERANKER=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Optional answer generation. Without this, the API returns extractive answers from cited PDF chunks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# CORS. Use comma-separated origins in production.
ALLOW_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://laoshan-song.github.io
